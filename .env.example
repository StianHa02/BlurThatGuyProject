# ── Frontend (runtime) ────────────────────────────────────────────────────────

# Backend URL — use service name when running in Docker
API_URL=http://backend:8000

# Shared API key between frontend and backend
API_KEY=your-secure-random-api-key-here

# ── Frontend (build-time — NEXT_PUBLIC_* are baked into the JS bundle) ────────

# Public URL of the Next.js API proxy (same host as frontend, so just leave blank
# or set to your domain — e.g. https://blurthatguy.no)
NEXT_PUBLIC_API_URL=

# Set to 1 to enable auth + My Videos. 0 to run as anonymous public tool.
NEXT_PUBLIC_USER_INTEGRATION=1

# Supabase — safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# ── Frontend (runtime, server-side only — never exposed to browser) ───────────

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-north-1
AWS_S3_BUCKET_NAME=your-bucket-name

# ── Backend (runtime) ─────────────────────────────────────────────────────────

# Same key as API_KEY above
# API_KEY=your-secure-random-api-key-here  # already set above, Docker injects it to both

ALLOWED_ORIGINS=https://your-domain.com
REDIS_URL=redis://redis:6379

# Optional
# MAX_UPLOAD_SIZE_MB=500
# TOTAL_THREAD_BUDGET=28
